#!/usr/bin/env bash
# Shipworthy — Post-Tool-Use Hook
# Fires after Bash commands (async). Advisory monitoring for commits and dependency changes.

set -euo pipefail

# --- Error recovery: always output valid JSON ---
trap 'echo "{}"' ERR

# --- Source shared library ---
PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$PLUGIN_ROOT/hooks/lib.sh" 2>/dev/null || true

# --- Read tool input from stdin (handle empty input) ---
INPUT=$(cat 2>/dev/null || true)

if [ -z "$INPUT" ]; then
  echo '{}'
  exit 0
fi

# --- Extract the command that was run using robust parser ---
COMMAND=$(parse_json_field "$INPUT" "command" 2>/dev/null || true)

if [ -z "$COMMAND" ]; then
  echo '{}'
  exit 0
fi

MESSAGE=""

# ============================================================
# Monitor: git commit detected
# ============================================================
if echo "$COMMAND" | grep -q "git commit" 2>/dev/null; then
  if echo "$COMMAND" | grep -q "\-\-amend" 2>/dev/null; then
    sw_log warn post-tool-use "Commit --amend detected"
    sw_signal "post-tool-use" "git" "amend-commit: may rewrite history"
    MESSAGE="[shipworthy] Commit amend detected. Verify: Was this intentional? Amending rewrites history — avoid on shared/pushed branches. Did you run tests after the amend?"
  else
    sw_log info post-tool-use "Commit detected — verification reminder issued"
    sw_signal "post-tool-use" "git" "commit: $(echo "$COMMAND" | head -c 200)"
    MESSAGE="[shipworthy] Commit detected. Verify: Did you run tests? Did you verify the change works? Does it follow the architecture spec?"
  fi
fi

# ============================================================
# Monitor: dependency changes
# ============================================================

# --- Installing existing dependencies (from lockfile/manifest) ---
if echo "$COMMAND" | grep -qE "^(npm ci|yarn install --frozen-lockfile|pnpm install --frozen-lockfile|pip install -r |go mod download|bundle install --deployment|cargo build)" 2>/dev/null; then
  # These are installing existing dependencies, not adding new ones. No warning needed.
  :
elif echo "$COMMAND" | grep -qE "^(npm install|yarn install|pnpm install|pip install -r|go mod download|bundle install)$" 2>/dev/null; then
  # Plain install commands without flags — installing from existing manifest
  :
# --- Adding a NEW dependency ---
elif echo "$COMMAND" | grep -qE "(npm install [a-zA-Z@]|yarn add |pnpm add |pip install [a-zA-Z]|go get |cargo add |gem install )" 2>/dev/null; then
  # Extract what's being installed
  DEP_NAME=""
  if echo "$COMMAND" | grep -qE "npm install " 2>/dev/null; then
    DEP_NAME=$(echo "$COMMAND" | sed 's/.*npm install //' | awk '{print $1}')
  elif echo "$COMMAND" | grep -qE "yarn add " 2>/dev/null; then
    DEP_NAME=$(echo "$COMMAND" | sed 's/.*yarn add //' | awk '{print $1}')
  elif echo "$COMMAND" | grep -qE "pnpm add " 2>/dev/null; then
    DEP_NAME=$(echo "$COMMAND" | sed 's/.*pnpm add //' | awk '{print $1}')
  elif echo "$COMMAND" | grep -qE "pip install " 2>/dev/null; then
    DEP_NAME=$(echo "$COMMAND" | sed 's/.*pip install //' | awk '{print $1}')
  elif echo "$COMMAND" | grep -qE "go get " 2>/dev/null; then
    DEP_NAME=$(echo "$COMMAND" | sed 's/.*go get //' | awk '{print $1}')
  elif echo "$COMMAND" | grep -qE "cargo add " 2>/dev/null; then
    DEP_NAME=$(echo "$COMMAND" | sed 's/.*cargo add //' | awk '{print $1}')
  fi

  # Skip flags (things starting with -)
  if [ -n "$DEP_NAME" ] && [[ "$DEP_NAME" != -* ]]; then
    sw_log info post-tool-use "New dependency: $DEP_NAME"
    sw_signal "post-tool-use" "dependency" "added: ${DEP_NAME}"
    MESSAGE="[shipworthy] New dependency added: ${DEP_NAME}. Consider: Is it well-maintained? Are there known vulnerabilities? Is the license compatible? Is the bundle size impact acceptable? Update architecture spec if this changes the tech stack."
  fi
fi

# ============================================================
# Monitor: force push detected
# ============================================================
if echo "$COMMAND" | grep -qE "git push.*(--force|-f)" 2>/dev/null; then
  sw_log warn post-tool-use "Force push detected"
  sw_signal "post-tool-use" "git" "force-push: dangerous history rewrite"
  MESSAGE="[shipworthy] Force push detected. This rewrites remote history. Verify: Is this a shared branch? Have other contributors pulled? Consider --force-with-lease instead."
fi

# ============================================================
# Monitor: database migration
# ============================================================
if echo "$COMMAND" | grep -qE "(migrate|migration|db:migrate|prisma migrate|alembic|knex migrate|typeorm migration)" 2>/dev/null; then
  sw_log info post-tool-use "Database migration detected"
  sw_signal "post-tool-use" "migration" "detected: $(echo "$COMMAND" | head -c 200)"
  if [ -z "$MESSAGE" ]; then
    MESSAGE="[shipworthy] Database migration detected. Verify: Is the migration reversible? Have you tested rollback? Is the migration safe for zero-downtime deployment?"
  fi
fi

# ============================================================
# Output result
# ============================================================
if [ -n "$MESSAGE" ]; then
  ESCAPED_MSG=$(printf '%s' "$MESSAGE" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g' | tr -d '\n\r')
  echo "{\"hookSpecificOutput\":{\"message\":\"${ESCAPED_MSG}\"}}"
else
  echo '{}'
fi
