#!/usr/bin/env bash
# Shipworthy — Post-Tool-Use Hook (Write/Edit)
# Fires after Write/Edit operations. Advisory architecture compliance check.
# Checks if written file path aligns with project structure conventions.

set -euo pipefail

# --- Error recovery: always output valid JSON ---
trap 'echo "{}"' ERR

# --- Source shared library ---
PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$PLUGIN_ROOT/hooks/lib.sh" 2>/dev/null || true

# --- Read tool input from stdin ---
INPUT=$(cat 2>/dev/null || true)

if [ -z "$INPUT" ]; then
  echo '{}'
  exit 0
fi

# --- Resolve project root ---
PROJECT_ROOT="$(timeout 2 git rev-parse --show-toplevel 2>/dev/null || pwd)"
ARCH_SPEC_PATH="$PROJECT_ROOT/.shipworthy/architecture.md"

# --- Extract file path using robust parser ---
FILE_PATH=$(parse_json_field "$INPUT" "file_path" 2>/dev/null || true)

# --- Check if path should be ignored ---
if [ -n "$FILE_PATH" ] && is_ignored_path "$FILE_PATH" "$PROJECT_ROOT" 2>/dev/null; then
  echo '{}'
  exit 0
fi

if [ -z "$FILE_PATH" ]; then
  echo '{}'
  exit 0
fi

sw_log info post-tool-use-write "Checking: $(basename "$FILE_PATH" 2>/dev/null || echo 'unknown')"

MESSAGE=""

# ============================================================
# Check 1: Test file written outside test directories
# ============================================================
BASENAME=$(basename "$FILE_PATH" 2>/dev/null || true)
if [[ "$BASENAME" == *test* ]] || [[ "$BASENAME" == *spec* ]] || [[ "$BASENAME" == test_* ]]; then
  RELATIVE_PATH="${FILE_PATH#$PROJECT_ROOT/}"
  if [[ "$RELATIVE_PATH" != tests/* ]] && [[ "$RELATIVE_PATH" != __tests__/* ]] && \
     [[ "$RELATIVE_PATH" != test/* ]] && [[ "$RELATIVE_PATH" != spec/* ]] && \
     [[ "$RELATIVE_PATH" != */tests/* ]] && [[ "$RELATIVE_PATH" != */__tests__/* ]] && \
     [[ "$RELATIVE_PATH" != */test/* ]]; then
    # Check if colocated tests are the convention (test files next to source)
    if [ -f "$ARCH_SPEC_PATH" ] && grep -qi "colocat" "$ARCH_SPEC_PATH" 2>/dev/null; then
      : # Colocated tests are the convention, no warning
    else
      sw_check post-tool-use-write "Test file location" warn
      sw_signal "post-tool-use-write" "pattern" "test-misplaced: $(basename "$FILE_PATH" 2>/dev/null || echo 'unknown')"
      MESSAGE="${MESSAGE}Test file written outside standard test directory. If this is intentional (colocated tests), update architecture spec. "
    fi
  fi
fi

# ============================================================
# Check 2: TypeScript `: any` usage (post-write verification)
# ============================================================
if [[ "$FILE_PATH" == *.ts ]] || [[ "$FILE_PATH" == *.tsx ]]; then
  if [ -f "$FILE_PATH" ]; then
    BASENAME_CHECK=$(basename "$FILE_PATH" 2>/dev/null || true)
    if [[ "$BASENAME_CHECK" != *.d.ts ]]; then
      # Check config override
      if [ "$(read_config 'overrides.allow_any_types' "$PROJECT_ROOT" 2>/dev/null)" != "true" ]; then
        # Use word boundary and skip comments (lines starting with // or *)
        ANY_COUNT=$(grep -v '^\s*//' "$FILE_PATH" 2>/dev/null | grep -v '^\s*\*' | grep -cE ':\s*any\b' 2>/dev/null || echo "0")
        if [ "$ANY_COUNT" -gt 0 ]; then
          sw_check post-tool-use-write "TypeScript :any" warn
          sw_signal "post-tool-use-write" "pattern" "typescript-any: ${ANY_COUNT} instance(s) in $(basename "$FILE_PATH" 2>/dev/null || echo 'unknown')"
          MESSAGE="${MESSAGE}TypeScript file contains ${ANY_COUNT} instance(s) of ': any'. Use 'unknown' with type guards instead. "
        fi
      fi
    fi
  fi
fi

# ============================================================
# Check 3: New route handler without validation import
# ============================================================
if [ -f "$FILE_PATH" ]; then
  if grep -qE '(app\.(get|post|put|patch|delete)|router\.(get|post|put|patch|delete)|@(Get|Post|Put|Patch|Delete))' "$FILE_PATH" 2>/dev/null; then
    if ! grep -qE '(zod|Zod|z\.|Pydantic|pydantic|validator)' "$FILE_PATH" 2>/dev/null; then
      sw_check post-tool-use-write "Route validation" warn
      sw_signal "post-tool-use-write" "pattern" "route-no-validation: $(basename "$FILE_PATH" 2>/dev/null || echo 'unknown')"
      MESSAGE="${MESSAGE}Route handler detected without input validation import. Consider adding Zod (JS/TS) or Pydantic (Python). "
    fi
  fi
fi

# ============================================================
# Check 4: Regression fence violation detection
# ============================================================
FENCE_PATH="$PROJECT_ROOT/.shipworthy/regression-fence.md"
if [ -f "$FENCE_PATH" ] && [ -f "$FILE_PATH" ]; then
  WRITTEN_CONTENT=$(cat "$FILE_PATH" 2>/dev/null || true)
  while IFS= read -r rule_heading; do
    [ -z "$rule_heading" ] && continue
    rule_text="${rule_heading#\#\# }"
    # Match "NEVER use X" patterns — check if X appears in the written file
    if echo "$rule_text" | grep -qiE '^NEVER use ' 2>/dev/null; then
      forbidden=$(echo "$rule_text" | sed 's/^NEVER use //i' | awk '{print $1}')
      if [ -n "$forbidden" ] && echo "$WRITTEN_CONTENT" | grep -qi "$forbidden" 2>/dev/null; then
        sw_check post-tool-use-write "Regression fence" warn
        sw_signal "post-tool-use-write" "fence-violation" "${rule_text} in $(basename "$FILE_PATH" 2>/dev/null || echo 'unknown')"
        MESSAGE="${MESSAGE}Regression fence violation: ${rule_text}. Check .shipworthy/regression-fence.md. "
        break  # One warning is enough, don't spam
      fi
    fi
  done < <(grep '^## ' "$FENCE_PATH" 2>/dev/null || true)
fi

# ============================================================
# Output result
# ============================================================
if [ -n "$MESSAGE" ]; then
  ESCAPED_MSG=$(printf '%s' "$MESSAGE" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g' | tr -d '\n\r')
  echo "{\"hookSpecificOutput\":{\"message\":\"[shipworthy] Advisory: ${ESCAPED_MSG}\"}}"
else
  sw_log info post-tool-use-write "Compliance OK ✓"
  echo '{}'
fi
