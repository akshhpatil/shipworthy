#!/usr/bin/env bash
# Shipworthy — Pre-Tool-Use Hook
# Fires before Write/Edit operations. Lightweight architecture enforcement.
# String-level checks only (no AST) — must be FAST.
# Advisory only: never blocks, only warns.

set -euo pipefail

# --- Error recovery: always output valid JSON ---
trap 'echo "{\"hookSpecificOutput\":{\"decision\":\"approve\"}}"' ERR

# --- Source shared library ---
PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$PLUGIN_ROOT/hooks/lib.sh" 2>/dev/null || true

# --- Read tool input from stdin (handle empty input) ---
INPUT=$(cat 2>/dev/null || true)

if [ -z "$INPUT" ]; then
  echo '{"hookSpecificOutput":{"decision":"approve"}}'
  exit 0
fi

# --- Resolve project root ---
PROJECT_ROOT="$(timeout 2 git rev-parse --show-toplevel 2>/dev/null || pwd)"

# --- Extract file path using robust parser ---
FILE_PATH=$(parse_json_field "$INPUT" "file_path" 2>/dev/null || true)

# --- Use full input as content for pattern matching ---
CONTENT="$INPUT"

# --- Check if path should be ignored per project config ---
if [ -n "$FILE_PATH" ] && is_ignored_path "$FILE_PATH" "$PROJECT_ROOT" 2>/dev/null; then
  echo '{"hookSpecificOutput":{"decision":"approve"}}'
  exit 0
fi

WARNINGS=""

# ============================================================
# Check 1: Detect secrets and credentials in content
# ============================================================
if [ -n "$CONTENT" ]; then
  # AWS Access Key IDs (start with AKIA)
  if echo "$CONTENT" | grep -qE 'AKIA[0-9A-Z]{16}'; then
    WARNINGS="${WARNINGS}AWS Access Key ID detected (AKIA...). Use environment variables or AWS credentials file. "
  fi

  # Generic secret/password/token/key patterns with values (handles JSON-escaped quotes too)
  if echo "$CONTENT" | grep -qiE '(password|secret|api_key|apikey|api-key|private_key|access_token|auth_token|secret_key|client_secret)[[:space:]]*[:=][[:space:]]*(\\?["\x27])[^"\\]{8,}'; then
    WARNINGS="${WARNINGS}Potential hardcoded secret detected. Use environment variables instead. "
  fi

  # Long hex strings (potential tokens/hashes — 40+ hex chars)
  # Exclude: git commit SHAs (preceded by commit/sha/hash/ref), UUIDs, and test files
  if echo "$CONTENT" | grep -qE '[0-9a-fA-F]{40,}'; then
    # Check it's not a known safe pattern
    if ! echo "$CONTENT" | grep -qiE '(commit|sha|hash|ref|digest|checksum)[[:space:]]*[:=]?[[:space:]]*["\x27]?[0-9a-fA-F]{40,}'; then
      if [ -z "$FILE_PATH" ] || { [[ "$FILE_PATH" != *test* ]] && [[ "$FILE_PATH" != *spec* ]] && [[ "$FILE_PATH" != *fixture* ]]; }; then
        WARNINGS="${WARNINGS}Long hex string detected — could be a hardcoded token or key. Verify this is not a secret. "
      fi
    fi
  fi

  # Base64-encoded strings that look like secrets (long base64 after a key-like variable)
  if echo "$CONTENT" | grep -qiE '(key|token|secret|password|credential)[[:space:]]*[:=][[:space:]]*["\x27][A-Za-z0-9+/]{40,}={0,2}["\x27]'; then
    WARNINGS="${WARNINGS}Potential base64-encoded secret detected. Use environment variables instead. "
  fi

  # Common API key patterns (sk-..., pk-..., rk_live_, sk_live_, etc.)
  if echo "$CONTENT" | grep -qE '(sk-[a-zA-Z0-9]{20,}|pk-[a-zA-Z0-9]{20,}|sk_live_[a-zA-Z0-9]{20,}|rk_live_[a-zA-Z0-9]{20,}|pk_live_[a-zA-Z0-9]{20,})'; then
    WARNINGS="${WARNINGS}API key pattern detected (sk-/pk-/live key). Use environment variables instead. "
  fi
fi

# ============================================================
# Check 2: Detect eval() and Function() constructor calls
# ============================================================
if [ -n "$CONTENT" ]; then
  if echo "$CONTENT" | grep -qE 'eval\s*\('; then
    WARNINGS="${WARNINGS}eval() detected — this is a security risk. Consider safer alternatives. "
  fi
  if echo "$CONTENT" | grep -qE 'new\s+Function\s*\('; then
    WARNINGS="${WARNINGS}new Function() constructor detected — equivalent to eval(). Consider safer alternatives. "
  fi
fi

# ============================================================
# Check 3: Detect writing to .env files
# ============================================================
if [ -n "$FILE_PATH" ]; then
  BASENAME=$(basename "$FILE_PATH" 2>/dev/null || true)
  if [[ "$BASENAME" == .env* ]]; then
    # Check if .gitignore exists and includes .env
    GITIGNORE_PATH="$PROJECT_ROOT/.gitignore"
    if [ -f "$GITIGNORE_PATH" ] && grep -q '\.env' "$GITIGNORE_PATH" 2>/dev/null; then
      : # .env is gitignored, no warning needed
    else
      WARNINGS="${WARNINGS}Writing to $BASENAME — ensure this file is in .gitignore to prevent committing secrets. "
    fi
  fi
fi

# ============================================================
# Check 4: console.log in production code
# ============================================================
if [ -n "$FILE_PATH" ] && [ -n "$CONTENT" ]; then
  FILE_BASENAME=$(basename "$FILE_PATH" 2>/dev/null || true)
  FILE_DIRNAME=$(dirname "$FILE_PATH" 2>/dev/null || true)

  # Skip test files, CLI tools, scripts, and bin directories
  SKIP_CONSOLE_CHECK="false"
  [[ "$FILE_BASENAME" == *test* ]] && SKIP_CONSOLE_CHECK="true"
  [[ "$FILE_BASENAME" == *spec* ]] && SKIP_CONSOLE_CHECK="true"
  [[ "$FILE_DIRNAME" == *__tests__* ]] && SKIP_CONSOLE_CHECK="true"
  [[ "$FILE_DIRNAME" == *__mocks__* ]] && SKIP_CONSOLE_CHECK="true"
  [[ "$FILE_DIRNAME" == */cli/* ]] && SKIP_CONSOLE_CHECK="true"
  [[ "$FILE_DIRNAME" == */bin/* ]] && SKIP_CONSOLE_CHECK="true"
  [[ "$FILE_DIRNAME" == */scripts/* ]] && SKIP_CONSOLE_CHECK="true"

  # Check project config override
  if [ "$(read_config 'overrides.allow_console_log' "$PROJECT_ROOT" 2>/dev/null)" = "true" ]; then
    SKIP_CONSOLE_CHECK="true"
  fi

  if [ "$SKIP_CONSOLE_CHECK" = "false" ]; then
    # Only match actual console.log calls, not strings or comments mentioning it
    if echo "$CONTENT" | grep -qE '[^/]console\.log\s*\(|^console\.log\s*\('; then
      WARNINGS="${WARNINGS}console.log detected in production code — use structured logging instead. "
    fi
  fi
fi

# ============================================================
# Output result
# ============================================================
if [ -n "$WARNINGS" ]; then
  # Escape warnings for JSON
  ESCAPED_WARNINGS=$(printf '%s' "$WARNINGS" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g' | tr -d '\n\r')
  echo "{\"hookSpecificOutput\":{\"decision\":\"approve\",\"message\":\"[shipworthy] Advisory: ${ESCAPED_WARNINGS}\"}}"
else
  echo '{"hookSpecificOutput":{"decision":"approve"}}'
fi
