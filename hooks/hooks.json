{
  "$comment": "Reference template for Claude Code hooks. The actual hooks are written to .claude/settings.json by 'npx shipworthy init' with absolute paths.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"/path/to/shipworthy/hooks/session-start\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/path/to/shipworthy/hooks/pre-tool-use\"",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"/path/to/shipworthy/hooks/pre-tool-use-bash\"",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"/path/to/shipworthy/hooks/pre-push-validate\"",
            "timeout": 90000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"/path/to/shipworthy/hooks/post-tool-use\"",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/path/to/shipworthy/hooks/post-tool-use-write\"",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
