#!/usr/bin/env bash
# Shipworthy — Session Start Hook
# Fires on every Claude Code session start. Injects:
# 1. Master routing skill (using-shipworthy)
# 2. Architecture spec constraints (if architecture.md exists)
# 3. Tech debt summary (if tech-debt.md exists)
# 4. User experience tier detection

set -euo pipefail

# --- Error recovery: always output valid JSON ---
trap 'echo "{\"hookSpecificOutput\":{\"additionalContext\":\"[shipworthy] Session hook encountered an error. Skills are still available — invoke them manually.\"}}"' ERR

# --- Source shared library ---
PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# shellcheck source=hooks/lib.sh
source "$PLUGIN_ROOT/hooks/lib.sh" 2>/dev/null || true

# --- Resolve paths robustly (with timeout for corporate proxies) ---
PROJECT_ROOT="$(timeout 3 git rev-parse --show-toplevel 2>/dev/null || pwd)"

debug_log "session-start" "Starting. PROJECT_ROOT=$PROJECT_ROOT"

# --- Idempotency: use PPID (Claude Code process) not $$ (hook process) ---
# Use user-owned directory (not world-writable /tmp) to prevent symlink attacks
MARKER_DIR="${HOME}/.shipworthy/sessions"
mkdir -p "$MARKER_DIR" 2>/dev/null || true
MARKER_NAME="session-$(printf '%s' "$PROJECT_ROOT" | shasum -a 256 | cut -c1-16)-${PPID:-$$}"
MARKER_FILE="$MARKER_DIR/$MARKER_NAME"
# Allow force reload via env var
if [ -f "$MARKER_FILE" ] && [ "${SHIPWORTHY_FORCE_RELOAD:-0}" != "1" ]; then
  sw_log info session-start "Context already loaded (session reuse)"
  echo '{"hookSpecificOutput":{"additionalContext":"[shipworthy] Context already loaded for this session."}}'
  exit 0
fi

# --- User Experience Tier Detection ---
detect_tier() {
  local has_code="false"
  local has_tests="false"
  local has_ci="false"
  local has_arch="false"

  # Check for code indicators
  if [ -f "$PROJECT_ROOT/package.json" ] || \
     [ -f "$PROJECT_ROOT/requirements.txt" ] || \
     [ -f "$PROJECT_ROOT/pyproject.toml" ] || \
     [ -f "$PROJECT_ROOT/go.mod" ] || \
     [ -f "$PROJECT_ROOT/Cargo.toml" ] || \
     [ -f "$PROJECT_ROOT/pom.xml" ] || \
     [ -f "$PROJECT_ROOT/build.gradle" ] || \
     [ -f "$PROJECT_ROOT/Makefile" ] || \
     [ -f "$PROJECT_ROOT/setup.py" ]; then
    has_code="true"
  fi

  # Check for test files
  if [ -d "$PROJECT_ROOT/tests" ] || \
     [ -d "$PROJECT_ROOT/__tests__" ] || \
     [ -d "$PROJECT_ROOT/test" ] || \
     [ -d "$PROJECT_ROOT/spec" ]; then
    has_tests="true"
  fi
  # Also check for test file patterns if no test directory found
  # Fast path: check package.json for test script (avoids slow find on large repos)
  if [ "$has_tests" = "false" ] && [ -f "$PROJECT_ROOT/package.json" ]; then
    if grep -q '"test"' "$PROJECT_ROOT/package.json" 2>/dev/null; then
      has_tests="true"
    fi
  fi
  # Slow path: filesystem scan with 2-second timeout to prevent hanging on monorepos
  if [ "$has_tests" = "false" ]; then
    local test_count
    test_count=$(timeout 2 find "$PROJECT_ROOT" -maxdepth 3 -type f \( -name "*.test.*" -o -name "*.spec.*" -o -name "test_*.py" -o -name "*_test.go" -o -name "*_test.rs" \) -not -path "*/node_modules/*" -not -path "*/.venv/*" 2>/dev/null | head -3 | wc -l | tr -d ' ')
    if [ "$test_count" -gt 0 ]; then
      has_tests="true"
    fi
  fi

  # Check for CI configuration
  if [ -d "$PROJECT_ROOT/.github/workflows" ] || \
     [ -f "$PROJECT_ROOT/.gitlab-ci.yml" ] || \
     [ -f "$PROJECT_ROOT/.circleci/config.yml" ] || \
     [ -f "$PROJECT_ROOT/Jenkinsfile" ] || \
     [ -f "$PROJECT_ROOT/.travis.yml" ] || \
     [ -f "$PROJECT_ROOT/azure-pipelines.yml" ] || \
     [ -d "$PROJECT_ROOT/.buildkite" ]; then
    has_ci="true"
  fi

  # Check for architecture spec
  if [ -f "$PROJECT_ROOT/.shipworthy/architecture.md" ]; then
    has_arch="true"
  fi

  # Determine tier
  if [ "$has_code" = "false" ] || [ "$has_tests" = "false" ]; then
    echo "builder"
  elif [ "$has_code" = "true" ] && [ "$has_tests" = "true" ] && { [ "$has_ci" = "true" ] || [ "$has_arch" = "true" ]; }; then
    echo "engineer"
  else
    echo "maker"
  fi
}

# --- Load preset configuration if present ---
PRESET_NAME=""
SHIPWORTHY_CONFIG="$PROJECT_ROOT/.shipworthy/config.json"
if [ -f "$SHIPWORTHY_CONFIG" ]; then
  PRESET_NAME=$(read_config "preset" "$PROJECT_ROOT" 2>/dev/null || true)
fi

TIER=$(detect_tier)
sw_log info session-start "Tier: $(echo "$TIER" | tr '[:lower:]' '[:upper:]')"

# Override tier if preset specifies one
if [ -n "$PRESET_NAME" ]; then
  PRESET_FILE="$PLUGIN_ROOT/presets/${PRESET_NAME}.json"
  if [ -f "$PRESET_FILE" ]; then
    PRESET_TIER=$(_SW_PF="$PRESET_FILE" python3 -c '
import json, os
try: print(json.load(open(os.environ["_SW_PF"])).get("tier",""), end="")
except: pass
' 2>/dev/null || true)
    if [ -n "$PRESET_TIER" ]; then
      TIER="$PRESET_TIER"
    fi
  fi
fi

# --- Fast Project Diagnosis (lightweight gap detection) ---
diagnose_gaps() {
  local gaps=""
  local gap_count=0
  local max_severity="none"

  # Check: .gitignore exists
  if [ ! -f "$PROJECT_ROOT/.gitignore" ]; then
    gaps="${gaps}no .gitignore, "
    gap_count=$((gap_count + 1))
    max_severity="medium"
  fi

  # Check: .env in .gitignore (critical)
  if [ -f "$PROJECT_ROOT/.gitignore" ]; then
    if ! grep -q '\.env' "$PROJECT_ROOT/.gitignore" 2>/dev/null; then
      # Only flag if .env files exist or the project has code
      if [ -f "$PROJECT_ROOT/.env" ] || [ "$TIER" != "builder" ]; then
        gaps="${gaps}.env not in .gitignore, "
        gap_count=$((gap_count + 1))
        max_severity="critical"
      fi
    fi
  fi

  # Check: test directory exists
  if [ ! -d "$PROJECT_ROOT/tests" ] && [ ! -d "$PROJECT_ROOT/__tests__" ] && \
     [ ! -d "$PROJECT_ROOT/test" ] && [ ! -d "$PROJECT_ROOT/spec" ]; then
    local test_count
    test_count=$(timeout 2 find "$PROJECT_ROOT" -maxdepth 3 -type f \( -name "*.test.*" -o -name "*.spec.*" -o -name "test_*.py" -o -name "*_test.go" \) -not -path "*/node_modules/*" -not -path "*/.venv/*" 2>/dev/null | head -3 | wc -l | tr -d ' ')
    if [ "$test_count" -eq 0 ] && [ "$TIER" != "builder" ]; then
      gaps="${gaps}no tests, "
      gap_count=$((gap_count + 1))
      if [ "$max_severity" != "critical" ]; then max_severity="high"; fi
    fi
  fi

  # Check: CI config exists
  if [ ! -d "$PROJECT_ROOT/.github/workflows" ] && \
     [ ! -f "$PROJECT_ROOT/.gitlab-ci.yml" ] && \
     [ ! -f "$PROJECT_ROOT/.circleci/config.yml" ] && \
     [ ! -f "$PROJECT_ROOT/Jenkinsfile" ]; then
    if [ "$TIER" = "engineer" ] || [ "$TIER" = "maker" ]; then
      gaps="${gaps}no CI, "
      gap_count=$((gap_count + 1))
      if [ "$max_severity" = "none" ]; then max_severity="medium"; fi
    fi
  fi

  # Check: linter configured
  local has_linter="false"
  if [ -f "$PROJECT_ROOT/eslint.config.js" ] || [ -f "$PROJECT_ROOT/eslint.config.mjs" ] || \
     [ -f "$PROJECT_ROOT/.eslintrc.js" ] || [ -f "$PROJECT_ROOT/.eslintrc.json" ] || \
     [ -f "$PROJECT_ROOT/.eslintrc.yml" ] || [ -f "$PROJECT_ROOT/ruff.toml" ] || \
     [ -f "$PROJECT_ROOT/.golangci.yml" ]; then
    has_linter="true"
  fi
  # Check pyproject.toml for ruff config
  if [ "$has_linter" = "false" ] && [ -f "$PROJECT_ROOT/pyproject.toml" ]; then
    if grep -q '\[tool\.ruff\]' "$PROJECT_ROOT/pyproject.toml" 2>/dev/null; then
      has_linter="true"
    fi
  fi
  if [ "$has_linter" = "false" ] && [ "$TIER" != "builder" ]; then
    gaps="${gaps}no linter, "
    gap_count=$((gap_count + 1))
    if [ "$max_severity" = "none" ]; then max_severity="medium"; fi
  fi

  # Check: architecture spec exists
  if [ ! -f "$PROJECT_ROOT/.shipworthy/architecture.md" ]; then
    gaps="${gaps}no architecture spec, "
    gap_count=$((gap_count + 1))
    if [ "$max_severity" = "none" ]; then max_severity="low"; fi
  fi

  # Output result
  if [ "$gap_count" -eq 0 ]; then
    echo "all checks passed"
  else
    # Remove trailing comma and space
    gaps="${gaps%, }"
    echo "${gap_count} gaps (${max_severity}): ${gaps}"
  fi
}

PROJECT_HEALTH=$(diagnose_gaps)
sw_log info session-start "Health: $PROJECT_HEALTH"

# --- Load master routing skill ---
MASTER_SKILL_PATH="$PLUGIN_ROOT/skills/core/using-shipworthy/SKILL.md"
CONTEXT=""

if [ -f "$MASTER_SKILL_PATH" ]; then
  MASTER_SKILL=$(cat "$MASTER_SKILL_PATH")
  CONTEXT="$MASTER_SKILL"
fi

# --- Inject tier information ---
CONTEXT="$CONTEXT

---

## USER EXPERIENCE TIER: $(echo "$TIER" | tr '[:lower:]' '[:upper:]')

Detected tier: **$TIER**
- **builder**: Project has no code or no tests. Focus on scaffolding, generating code, and introducing testing gradually. Use streamlined workflows. Skip advanced planning unless the user asks for it.
- **maker**: Project has code and some tests but lacks CI or architecture spec. Use standard workflows. Encourage adding CI and architecture documentation.
- **engineer**: Project has code, tests, CI, and/or architecture spec. Use full engineering workflows. Enforce all quality gates and verification standards.

Adapt skill behavior to this tier. For example:
- Brainstorming: 3-step for builder/maker, full 5-step for engineer
- Quality gates: relaxed for builder, standard for maker, strict for engineer
- Architecture awareness: suggest for builder, recommend for maker, require for engineer

## PROJECT HEALTH: $PROJECT_HEALTH

Run \`/diagnose\` for a full infrastructure diagnosis with auto-fix options."

# --- Inject preset information if loaded ---
if [ -n "$PRESET_NAME" ]; then
  sw_log info session-start "Preset: $PRESET_NAME"
  PRESET_FILE="$PLUGIN_ROOT/presets/${PRESET_NAME}.json"
  if [ -f "$PRESET_FILE" ]; then
    SKIP_SKILLS=$(_SW_PF="$PRESET_FILE" python3 -c '
import json, os
try: print(", ".join(json.load(open(os.environ["_SW_PF"])).get("skip_skills",[])), end="")
except: pass
' 2>/dev/null || true)
    ACTIVE_CATS=$(_SW_PF="$PRESET_FILE" python3 -c '
import json, os
try: print(", ".join(json.load(open(os.environ["_SW_PF"])).get("active_categories",[])), end="")
except: pass
' 2>/dev/null || true)
    CONTEXT="$CONTEXT

---

## PRESET: $PRESET_NAME

Active categories: $ACTIVE_CATS
Skipped skills: $SKIP_SKILLS
When routing to skills, respect these filters — skip the listed skills and prioritize active categories."
  fi
fi

# --- Context budget: 8000 character limit ---
# Priority: Mandatory Rules > Tier > Project Health > Tech Debt > Plans > Session
CONTEXT_BUDGET=8000

# --- Load architecture spec if present ---
ARCH_SPEC_PATH="$PROJECT_ROOT/.shipworthy/architecture.md"

if [ -f "$ARCH_SPEC_PATH" ]; then
  sw_log info session-start "Architecture spec: loaded"
  ARCH_SPEC=$(cat "$ARCH_SPEC_PATH")
  ARCH_SECTION="

---

## PROJECT ARCHITECTURE SPECIFICATION (AUTO-LOADED)

The following architecture specification was generated for this project.
These Mandatory Rules are FIRST-CLASS CONSTRAINTS — treat them with the same priority as user instructions.

$ARCH_SPEC"

  # Check context budget
  COMBINED_LENGTH=$(( ${#CONTEXT} + ${#ARCH_SECTION} ))
  if [ "$COMBINED_LENGTH" -gt "$CONTEXT_BUDGET" ]; then
    # Extract Mandatory Rules section only for budget compliance
    MANDATORY_RULES=$(sed -n '/^## Mandatory Rules/,/^## [^M]/p' "$ARCH_SPEC_PATH" | sed '$d' 2>/dev/null || true)
    if [ -z "$MANDATORY_RULES" ]; then
      # Try alternate heading formats
      MANDATORY_RULES=$(sed -n '/^## Mandatory/,/^## /p' "$ARCH_SPEC_PATH" | sed '$d' 2>/dev/null || true)
    fi
    if [ -n "$MANDATORY_RULES" ]; then
      CONTEXT="$CONTEXT

---

## PROJECT ARCHITECTURE SPECIFICATION (SUMMARIZED — full spec at .shipworthy/architecture.md)

$MANDATORY_RULES

(Architecture spec was summarized to fit context budget. Read the full file for complete details.)"
    else
      # No Mandatory Rules section found; include a pointer
      CONTEXT="$CONTEXT

---

## PROJECT ARCHITECTURE SPECIFICATION (TRUNCATED)

Architecture spec exists at \`.shipworthy/architecture.md\` but is too large for context injection.
Read the file directly when making architectural decisions."
    fi
  else
    CONTEXT="$CONTEXT$ARCH_SECTION"
  fi
else
  sw_log info session-start "Architecture spec: not found"
  CONTEXT="$CONTEXT

---

## NO ARCHITECTURE SPECIFICATION FOUND

This project does not yet have an architecture specification at \`.shipworthy/architecture.md\`.

**On the first substantive coding request**, invoke the \`architecture-awareness\` skill to:
1. Detect the project type and tech stack
2. Analyze existing patterns (if any code exists)
3. Generate an architecture specification
4. Present it to the user for approval

Do NOT block the user's first request — but weave architecture discovery into the work naturally.
If the user explicitly says they don't want an architecture spec, respect that and proceed without one."
fi

# --- Load regression fence if present ---
FENCE_PATH="$PROJECT_ROOT/.shipworthy/regression-fence.md"
if [ -f "$FENCE_PATH" ]; then
  FENCE_COUNT=$(grep -c '^## ' "$FENCE_PATH" 2>/dev/null || echo "0")
  if [ "$FENCE_COUNT" -gt 0 ]; then
    sw_log info session-start "Regression fence: $FENCE_COUNT rule(s) loaded"
    FENCE_CONTENT=$(cat "$FENCE_PATH" 2>/dev/null || true)
    FENCE_SECTION="

---

## REGRESSION FENCE (AUTO-LOADED)

Known anti-patterns for this project. Identified in previous sessions via /retro.
Treat each rule as a HARD CONSTRAINT — violating these means repeating a known mistake.

$FENCE_CONTENT

(Edit \`.shipworthy/regression-fence.md\` or run \`/retro\` to manage.)"

    # Budget check
    COMBINED_LENGTH=$(( ${#CONTEXT} + ${#FENCE_SECTION} ))
    if [ "$COMBINED_LENGTH" -gt "$CONTEXT_BUDGET" ]; then
      # Extract just the headings (NEVER/ALWAYS rules) without explanations
      FENCE_SUMMARY=$(grep '^## ' "$FENCE_PATH" 2>/dev/null | head -20 || true)
      CONTEXT="$CONTEXT

---

## REGRESSION FENCE (SUMMARIZED — full at .shipworthy/regression-fence.md)

$FENCE_SUMMARY

(${FENCE_COUNT} rules. Read the full file for explanations.)"
    else
      CONTEXT="$CONTEXT$FENCE_SECTION"
    fi
  fi
fi

# --- Surface in-progress plans and recent session ---
PLANS_DIR="$PROJECT_ROOT/.shipworthy/plans"
SESSIONS_DIR="$PROJECT_ROOT/.shipworthy/sessions"

IN_PROGRESS_PLANS=""
if [ -d "$PLANS_DIR" ]; then
  for plan_file in "$PLANS_DIR"/*.md; do
    [ -f "$plan_file" ] || continue
    plan_name=$(basename "$plan_file" .md)
    IN_PROGRESS_PLANS="${IN_PROGRESS_PLANS}${plan_name}, "
  done
fi

if [ -n "$IN_PROGRESS_PLANS" ]; then
  IN_PROGRESS_PLANS="${IN_PROGRESS_PLANS%, }"
  sw_log info session-start "In-progress plans: $IN_PROGRESS_PLANS"
  CONTEXT="$CONTEXT

---

## IN-PROGRESS PLANS

Plans found in \`.shipworthy/plans/\`: **${IN_PROGRESS_PLANS}**
Check if any should be resumed before starting new work. Ask: \"You have plans for [feature]. Resume or start fresh?\""
fi

# Surface recent session summary
if [ -d "$SESSIONS_DIR" ]; then
  LATEST_SESSION=$(ls -t "$SESSIONS_DIR"/*.md 2>/dev/null | head -1)
  if [ -n "$LATEST_SESSION" ] && [ -f "$LATEST_SESSION" ]; then
    SESSION_DATE=$(basename "$LATEST_SESSION" .md)
    # Only surface if within last 7 days (basic check: file modified in last 7 days)
    if [ "$(find "$LATEST_SESSION" -mtime -7 2>/dev/null)" ]; then
      SESSION_SUMMARY=$(head -20 "$LATEST_SESSION" 2>/dev/null || true)
      if [ -n "$SESSION_SUMMARY" ]; then
        CONTEXT="$CONTEXT

---

## PREVIOUS SESSION ($SESSION_DATE)

$(echo "$SESSION_SUMMARY" | head -15)

(Full session log at \`.shipworthy/sessions/${SESSION_DATE}.md\`)"
      fi
    fi
  fi
fi

# --- Surface project learnings from retrospectives ---
LEARNINGS_DIR="$PROJECT_ROOT/.shipworthy/learnings"
if [ -d "$LEARNINGS_DIR" ]; then
  LEARNING_FILES=""
  LEARNING_COUNT=0
  for learning_file in "$LEARNINGS_DIR"/*.md; do
    [ -f "$learning_file" ] || continue
    learning_name=$(basename "$learning_file" .md)
    LEARNING_FILES="${LEARNING_FILES}${learning_name}, "
    LEARNING_COUNT=$((LEARNING_COUNT + 1))
  done
  if [ "$LEARNING_COUNT" -gt 0 ]; then
    LEARNING_FILES="${LEARNING_FILES%, }"
    CONTEXT="$CONTEXT

---

## PROJECT LEARNINGS (from retrospectives)

**${LEARNING_COUNT} learning file(s)** in \`.shipworthy/learnings/\`: ${LEARNING_FILES}
These capture what previous sessions taught us — preferences, patterns that work, patterns to avoid.
Read relevant learnings before starting similar work. Run \`/retro\` after completing work to capture new learnings."
  fi
fi

# --- Load tech debt summary if present ---
TECH_DEBT_PATH="$PROJECT_ROOT/.shipworthy/tech-debt.md"

if [ -f "$TECH_DEBT_PATH" ]; then
  DEBT_COUNT=$(grep -c "^## " "$TECH_DEBT_PATH" 2>/dev/null || echo "0")
  if [ "$DEBT_COUNT" -gt 0 ]; then
    CONTEXT="$CONTEXT

---

## TECH DEBT NOTICE
There are **$DEBT_COUNT tech debt item(s)** tracked in \`.shipworthy/tech-debt.md\`. Review when relevant."
  fi
fi

# --- Auto-retro: surface unprocessed session signals ---
SIGNALS_FILE="$PROJECT_ROOT/.shipworthy/.session-signals"
if [ -f "$SIGNALS_FILE" ]; then
  SIGNAL_COUNT=$(wc -l < "$SIGNALS_FILE" 2>/dev/null | tr -d ' ')
  if [ "$SIGNAL_COUNT" -gt 0 ]; then
    sw_log info session-start "Unprocessed signals: $SIGNAL_COUNT from last session"
    # Read last 20 signals for context (keep injection small)
    SIGNAL_PREVIEW=$(tail -20 "$SIGNALS_FILE" 2>/dev/null || true)
    CONTEXT="$CONTEXT

---

## AUTO-RETRO: UNPROCESSED SESSION SIGNALS

There are **${SIGNAL_COUNT} captured signal(s)** from the previous session in \`.shipworthy/.session-signals\`.
These were automatically captured by hooks (commits, security warnings, pattern detections, dependency changes).

**BEFORE starting new work**, process these signals:
1. Read \`.shipworthy/.session-signals\`
2. Group by category (security, pattern, dependency, git, migration, fence-violation)
3. For any repeated patterns or security warnings, propose regression fence entries:
   - Format: \`## NEVER [verb] [what] — [anchored to file path if possible]\`
   - Include a 1-line explanation with date
4. For dependency additions or migration events, propose learnings entries
5. Present a brief table: \`| # | Proposed Rule | Source | Destination |\`
6. Ask: \"Approve these context updates? (yes / select items / skip)\"
7. After processing, delete \`.shipworthy/.session-signals\`

Signal preview (last 20):
\`\`\`
${SIGNAL_PREVIEW}
\`\`\`"
  fi
fi

# --- Generate .shipworthy/INDEX.md (auto-refreshed each session) ---
# Survives context compaction — Claude can read this mid-session to rediscover project memory
generate_index() {
  [ -d "$PROJECT_ROOT/.shipworthy" ] || return 0

  local idx="# .shipworthy/ Index
> Auto-generated each session and after /retro. Read this to discover all project memory."

  # Architecture
  [ -f "$PROJECT_ROOT/.shipworthy/architecture.md" ] && \
    idx="${idx}

## Architecture
- architecture.md — Project architecture specification"

  # Config
  [ -f "$PROJECT_ROOT/.shipworthy/config.json" ] && \
    idx="${idx}

## Configuration
- config.json — Project overrides and preset"

  # Specs
  local spec_list=""
  for f in "$PROJECT_ROOT/.shipworthy/specs"/*.md; do
    [ -f "$f" ] || continue
    spec_list="${spec_list}
- $(basename "$f")"
  done
  [ -n "$spec_list" ] && idx="${idx}

## Specs${spec_list}"

  # Plans
  local plan_list=""
  for f in "$PROJECT_ROOT/.shipworthy/plans"/*.md; do
    [ -f "$f" ] || continue
    plan_list="${plan_list}
- $(basename "$f")"
  done
  [ -n "$plan_list" ] && idx="${idx}

## Plans${plan_list}"

  # Decisions
  local decision_list=""
  for f in "$PROJECT_ROOT/.shipworthy/decisions"/*.md; do
    [ -f "$f" ] || continue
    decision_list="${decision_list}
- $(basename "$f")"
  done
  [ -n "$decision_list" ] && idx="${idx}

## Decisions${decision_list}"

  # Learnings (with frontmatter descriptions when available)
  local learning_list=""
  for f in "$PROJECT_ROOT/.shipworthy/learnings"/*.md; do
    [ -f "$f" ] || continue
    local name
    name=$(basename "$f")
    local desc=""
    desc=$(sed -n '/^---$/,/^---$/{ /^description:/{ s/^description: *//; p; q; } }' "$f" 2>/dev/null || true)
    if [ -n "$desc" ]; then
      learning_list="${learning_list}
- ${name} — ${desc}"
    else
      learning_list="${learning_list}
- ${name}"
    fi
  done
  [ -n "$learning_list" ] && idx="${idx}

## Learnings${learning_list}"

  # Sessions (last 10 only)
  local session_list=""
  local shown=0
  for f in $(ls -t "$PROJECT_ROOT/.shipworthy/sessions"/*.md 2>/dev/null | head -10); do
    [ -f "$f" ] || continue
    session_list="${session_list}
- $(basename "$f")"
    shown=$((shown + 1))
  done
  if [ -n "$session_list" ]; then
    local total
    total=$(ls "$PROJECT_ROOT/.shipworthy/sessions"/*.md 2>/dev/null | wc -l | tr -d ' ')
    local hdr="## Sessions"
    [ "$total" -gt 10 ] && hdr="## Sessions (${shown} of ${total})"
    idx="${idx}

${hdr}${session_list}"
  fi

  # Regression Fence
  if [ -f "$PROJECT_ROOT/.shipworthy/regression-fence.md" ]; then
    local fc
    fc=$(grep -c "^## " "$PROJECT_ROOT/.shipworthy/regression-fence.md" 2>/dev/null || echo "0")
    idx="${idx}

## Regression Fence
- regression-fence.md — ${fc} rule(s)"
  fi

  # Tech Debt
  if [ -f "$PROJECT_ROOT/.shipworthy/tech-debt.md" ]; then
    local dc
    dc=$(grep -c "^## " "$PROJECT_ROOT/.shipworthy/tech-debt.md" 2>/dev/null || echo "0")
    idx="${idx}

## Tech Debt
- tech-debt.md — ${dc} item(s)"
  fi

  printf '%s\n' "$idx" > "$PROJECT_ROOT/.shipworthy/INDEX.md" 2>/dev/null || true
}

generate_index 2>/dev/null || true

# --- Add INDEX.md reference to context ---
if [ -f "$PROJECT_ROOT/.shipworthy/INDEX.md" ]; then
  CONTEXT="$CONTEXT

---

## PROJECT MEMORY INDEX

Full index of all project memory at \`.shipworthy/INDEX.md\`. If context was compacted and you lose track of what the project knows, read that file to rediscover specs, plans, learnings, decisions, and session history."
fi

# --- Transparency banner ---
sw_banner "$TIER" "$PROJECT_HEALTH"

# --- Escape and output for Claude Code ---
ESCAPED_CONTEXT=$(escape_json "$CONTEXT")

# --- Mark session as initialized ---
printf '%s\n' "$(date +%s)" > "$MARKER_FILE" 2>/dev/null || true
# Clean up stale markers older than 24 hours (non-blocking)
find "$MARKER_DIR" -maxdepth 1 -name "session-*" -mtime +1 -delete 2>/dev/null &

# --- Output for Claude Code ---
cat <<HOOKEOF
{"hookSpecificOutput":{"additionalContext":"$ESCAPED_CONTEXT"}}
HOOKEOF
